5:["$","$Lf",null,{"initialCategories":[{"id":"9a92e1ef-ba4d-4312-84fa-b1dda15400a3","slug":"ancillary-disposables","name":"Ancillary Surgical Disposables","description":"Our ancillary range provides complete sterile protection for clinical equipment and surgical staff. From specialized C-Arm and Camera covers to fluid-resistant leggings and shoe covers, we ensure a 360-degree sterile environment.","image":"https://images.unsplash.com/photo-1584622650111-993a426fbf0a?auto=format&fit=crop&q=80&w=800","createdAt":"$D2026-03-09T10:36:11.614Z","updatedAt":"$D2026-03-09T10:36:11.614Z"},{"id":"a1c6558c-2f57-4ca8-b3f9-97236c5e2afc","slug":"bed-sheets","name":"Disposable Bed Sheets & Covering","description":"Our disposable bed sheets and covering sheets provide a superior moisture barrier and hygiene. Made from premium SMS and PP Spunbond fabrics as per international clinical standards.","image":"https://images.unsplash.com/photo-1516549655169-df83a0774514?auto=format&fit=crop&q=80&w=800","createdAt":"$D2026-03-09T10:36:07.434Z","updatedAt":"$D2026-03-09T10:36:07.434Z"},{"id":"c90202e5-f084-40ee-ad59-d2ed87c24bcb","slug":"patient-gowns","name":"Disposable Patient Gowns/Kits","description":"Our patient gowns are lightweight, breathable, and provide excellent coverage. Available in various sleeve lengths and complete kits including bouffant caps, shoe covers, and patient towels.","image":"https://images.unsplash.com/photo-1516549655169-df83a0774514?auto=format&fit=crop&q=80&w=800","createdAt":"$D2026-03-09T10:36:09.523Z","updatedAt":"$D2026-03-09T10:36:09.523Z"},{"id":"8f4db121-0955-4f1a-8661-6db32225cac5","slug":"surgeon-gowns","name":"Disposable Surgeon Gowns","description":"From SMS Standard to Wrap-around Reinforced protection, our surgeon gowns are designed for maximum safety in the OR. Available in various GSMs including poly aprons and isolation gowns.","image":"https://images.unsplash.com/photo-1584622650111-993a426fbf0a?auto=format&fit=crop&q=80&w=800","createdAt":"$D2026-03-09T10:36:08.478Z","updatedAt":"$D2026-03-09T10:36:08.478Z"},{"id":"a92ccda1-d227-4071-bfed-a6670c8e27fc","slug":"general-surgery-drapes","name":"General Surgery Drapes","description":"Our general surgery drape packs are engineered for maximum fluid control and sterile field integrity. Includes Universal, Mini, and Specialized sagging packs to meet diverse clinical requirements.","image":"https://images.unsplash.com/photo-1579684385127-1ef15d508118?auto=format&fit=crop&q=80&w=800","createdAt":"$D2026-03-09T10:36:02.980Z","updatedAt":"$D2026-03-09T10:36:02.980Z"},{"id":"19e2cebd-44e7-49d2-ac9c-94e0dcbddf7d","slug":"gynae-surgery-drapes","name":"Gynecology Surgery Drapes","description":"Our gynecology range features amniotic-control SMS fabrics, integrated incise films, and super-absorbent maternity pads. Optimized for patient dignity and clinical efficiency in delivery rooms.","image":"https://images.unsplash.com/photo-1584622650111-993a426fbf0a?auto=format&fit=crop&q=80&w=800","createdAt":"$D2026-03-09T10:36:05.335Z","updatedAt":"$D2026-03-09T10:36:05.335Z"},{"id":"adee8752-53bd-47a7-8098-c12b7aa69c44","slug":"ortho-surgery-drapes","name":"Orthopedic Surgery Drapes","description":"Designed for high-fluid and high-mechanical stress procedures. Our Ortho drapes feature reinforced adhesive zones, limb sleeves, and integrated fluid collection pouches for Knee, Hip, and Shoulder surgeries.","image":"https://images.unsplash.com/photo-1581595224492-38411d82fc07?auto=format&fit=crop&q=80&w=800","createdAt":"$D2026-03-09T10:36:04.287Z","updatedAt":"$D2026-03-09T10:36:04.287Z"},{"id":"dafe1964-5253-4596-827d-b2946eda55f2","slug":"other-surgery-drapes","name":"Other Surgery Drapes","description":"Comprehensive range of specialized drapes for niche surgical sectors. From CABG cardiac packs to Neurology craniotomy drapes and IVF procedure kits, we provide total sterile solutions for advanced specialties.","image":"https://images.unsplash.com/photo-1516549655169-df83a0774514?auto=format&fit=crop&q=80&w=800","createdAt":"$D2026-03-09T10:36:06.386Z","updatedAt":"$D2026-03-09T10:36:06.386Z"},{"id":"eacfa566-f7d3-41bf-9ab2-445150ade30c","slug":"wrapping-sheets","name":"Sterilization Wrapping Sheets","description":"Made from high-performance SMS fabric (43/50 GSM), our wrapping sheets provide an effective microbial barrier. Available in multiple standard dimensions and customized sizes in packs of 25 and 50.","image":"https://images.unsplash.com/photo-1583324113626-70df0f43aa2b?auto=format&fit=crop&q=80&w=800","createdAt":"$D2026-03-09T10:36:10.568Z","updatedAt":"$D2026-03-09T10:36:10.568Z"}]}]
