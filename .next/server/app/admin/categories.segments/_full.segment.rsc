c:[["$","title","0",{"children":"KRG Medifabb | Clinical Excellence eCommerce"}],["$","meta","1",{"name":"description","content":"Global leader in surgical disposables and sterile medical textiles. High-performance manufacture for hospital networks."}],["$","meta","2",{"name":"author","content":"KRG Medifabb"}],["$","meta","3",{"name":"keywords","content":"surgical gowns,sterile drapes,medical textiles,KRG Medifabb,hospital disposables"}],["$","meta","4",{"name":"creator","content":"KRG Medifabb"}],["$","meta","5",{"name":"publisher","content":"KRG Medifabb"}],["$","meta","6",{"name":"format-detection","content":"telephone=no, address=no, email=no"}],["$","meta","7",{"property":"og:title","content":"KRG Medifabb | Surgical Disposables"}],["$","meta","8",{"property":"og:description","content":"Institutional-grade surgical drapes and gowns. Precision manufactured in India for global healthcare."}],["$","meta","9",{"property":"og:url","content":"https://krgmedifabb.com"}],["$","meta","10",{"property":"og:site_name","content":"KRG Medifabb"}],["$","meta","11",{"property":"og:locale","content":"en_US"}],["$","meta","12",{"property":"og:image","content":"https://krgmedifabb.com/og-image.jpg"}],["$","meta","13",{"property":"og:image:width","content":"1200"}],["$","meta","14",{"property":"og:image:height","content":"630"}],["$","meta","15",{"property":"og:image:alt","content":"KRG Medifabb Manufacturing"}],["$","meta","16",{"property":"og:type","content":"website"}],["$","meta","17",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","18",{"name":"twitter:title","content":"KRG Medifabb | Surgical Disposables"}],["$","meta","19",{"name":"twitter:description","content":"Global leader in sterile medical textiles."}],["$","meta","20",{"name":"twitter:image","content":"https://krgmedifabb.com/og-image.jpg"}],["$","link","21",{"rel":"icon","href":"/favicon.ico?favicon.0b3bf435.ico","sizes":"256x256","type":"image/x-icon"}],["$","$Le","22",{}]]
